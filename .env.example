# ===== Environment variables for deployment =====
# Copy these into Vercel → Project → Settings → Environment Variables

# Supabase PostgreSQL connection string (from Supabase → Connect → ORM/Prisma)
# Use the "Connection pooling" / "Transaction" string (port 6543) for DATABASE_URL on Vercel.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used by Prisma for migrations / db push
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# NextAuth — generate a random secret: run `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Your deployed app URL (Vercel gives you this, e.g. https://your-app.vercel.app)
NEXTAUTH_URL="https://your-app.vercel.app"
